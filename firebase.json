{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "database": "default",
    "location": "us-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/api/**", "function": "api" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html|svg|ico|png)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "favicon.ico",
        "headers": [{ "key": "Content-Type", "value": "image/x-icon" }]
      }
    ]
  }
}
